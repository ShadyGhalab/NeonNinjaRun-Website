---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
const appStoreUrl = "https://apps.apple.com/us/app/neon-ninja-run/id6766583123";

const highlights = [
  ["Parry combat", "Tap at the edge of danger to counter enemies and keep the combo alive."],
  ["Distinct chapters", "Run through storm, crystal, city, blossom, and endgame neon arenas."],
  ["Visible progression", "Earn upgrades, cosmetics, titles, trails, sound packs, and rewards."],
  ["Game Center", "Chase leaderboards, achievements, and cleaner runs across every mode."],
  ["Offline-friendly", "Play core runs anywhere, with online features when available."],
  ["Short sessions", "Quick runs, Time Attack, Survival, and modifiers keep every launch useful."]
];

const chapters = [
  {
    name: "Crystal Caverns",
    image: "neon-city.png",
    kicker: "Combo finishers, bright hazards",
    text: "A high-impact showcase of Kira's slash-ready moments, glowing pickups, and sharp timing windows."
  },
  {
    name: "Neon City",
    image: "storm-nexus.png",
    kicker: "Rain, signs, rooftop pressure",
    text: "Electric surges, city signs, and combo pressure turn every lane change into a quick decision."
  },
  {
    name: "Spirit Rapids",
    image: "frozen-tundra.png",
    kicker: "Storm flow, jumps, power-ups",
    text: "Keep your route clean through weather, hazards, and collectible paths built for momentum."
  },
  {
    name: "Volcanic Depths",
    image: "sakura-gardens.png",
    kicker: "Heat, bosses, heavy danger",
    text: "A heavier chapter mood with boss pressure, harder reads, and fewer quiet seconds."
  },
  {
    name: "Nexus Prime",
    image: "nexus-prime.png",
    kicker: "Final light, speed, finishers",
    text: "The run becomes a spectacle of light, enemies, powers, and decisive late-run moments."
  }
];

const modes = [
  ["Story", "Clear chapters, unlock lore, and push Kira deeper into the neon world."],
  ["Quick Play", "Start fast with your current upgrades, cosmetics, and best reflexes."],
  ["Time Attack", "Race short courses and sharpen clean execution."],
  ["Survival", "Stay alive through escalating pressure and enemy waves."],
  ["Modifiers", "Add extra challenge for bigger rewards and harder runs."],
  ["Weekly Events", "Return for rotating goals, milestones, and bonus rewards."]
];

const premium = [
  ["Remove Ads", "One purchase removes forced ads permanently."],
  ["Starter Pack", "A launch boost with Orbs, Gems, and ad removal."],
  ["Season 1 Pass", "Unlock the premium reward track and earn rewards with XP."],
  ["Orbs + Gems", "Buy upgrade currency and premium cosmetic currency directly."],
  ["Cosmetics", "Skins, trails, kill effects, emotes, titles, and sound packs."]
];
---

<BaseLayout
  title="Neon Ninja Run — Fast Action Arcade Runner"
  description="Dash as Kira through neon worlds, parry enemies, defeat bosses, unlock premium cosmetics, and chase Game Center leaderboards in a fast landscape arcade runner."
  image="images/neon-city.png"
>
  <section class="hero hero--home">
    <picture class="hero-media" aria-hidden="true">
      <img src={`${base}images/neon-city.png`} alt="" />
    </picture>
    <div class="hero-shade" aria-hidden="true"></div>
    <div class="hero-content">
      <p class="eyebrow">Available on the App Store</p>
      <h1>Neon Ninja Run</h1>
      <p class="hero-copy">Dash as Kira through neon worlds, parry enemies at the last second, defeat bosses, and unlock premium skins, trails, kill effects, titles, and sound packs.</p>
      <div class="hero-actions">
        <a class="store-badge" href={appStoreUrl} target="_blank" rel="noopener">
          <img src="https://tools.applemediaservices.com/api/badges/download-on-the-app-store/black/en-us?size=250x83" alt="Download on the App Store" />
        </a>
        <a class="button button--ghost" href="#chapters">See gameplay</a>
      </div>
    </div>
    <div class="hero-stats" aria-label="Game highlights">
      <span>Parry combat</span>
      <span>Boss chapters</span>
      <span>Offline-friendly</span>
    </div>
  </section>

  <section class="section intro-band">
    <div class="section-heading section-heading--split">
      <div>
        <p class="eyebrow">Why play</p>
        <h2>Fast runs with real combat decisions.</h2>
      </div>
      <p>Neon Ninja Run is built for quick sessions, but every run still has a point: better timing, cleaner routes, richer rewards, and sharper mastery.</p>
    </div>
    <div class="feature-strip feature-strip--dense">
      {highlights.map(([title, text]) => (
        <article>
          <strong>{title}</strong>
          <span>{text}</span>
        </article>
      ))}
    </div>
  </section>

  <section class="section chapter-showcase" id="chapters">
    <div class="section-heading">
      <p class="eyebrow">Gameplay worlds</p>
      <h2>Every chapter should feel like a different run.</h2>
    </div>
    <div class="chapter-grid">
      {chapters.map((chapter, index) => (
        <article class={`chapter-card chapter-card--${index + 1}`}>
          <img src={`${base}images/${chapter.image}`} alt={`${chapter.name} gameplay screenshot`} loading={index > 1 ? "lazy" : "eager"} />
          <div>
            <p>{chapter.kicker}</p>
            <h3>{chapter.name}</h3>
            <span>{chapter.text}</span>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section mode-section" id="modes">
    <div class="section-heading section-heading--split">
      <div>
        <p class="eyebrow">Modes and progression</p>
        <h2>Runs stay short. Mastery does not.</h2>
      </div>
      <p>Pick a focused run, chase a score, test a build, or turn on modifiers when you want bigger pressure and better rewards.</p>
    </div>
    <div class="mode-grid">
      {modes.map(([title, text]) => (
        <article class="mode-card">
          <h3>{title}</h3>
          <p>{text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section premium-section">
    <div class="premium-panel">
      <div>
        <p class="eyebrow">Premium value</p>
        <h2>Know exactly what you are buying.</h2>
        <p>Purchases are optional. They remove ads, speed up progression, or unlock visual style; they do not replace skill.</p>
      </div>
      <div class="premium-grid">
        {premium.map(([title, text]) => (
          <article>
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section cosmetic-section">
    <div class="wide-panel">
      <div>
        <p class="eyebrow">Cosmetics</p>
        <h2>Make Kira’s run yours.</h2>
        <p>Collect visible upgrades for how the run looks and feels, from trails and emotes to kill effects and sound packs.</p>
      </div>
      <div class="cosmetic-list" aria-label="Cosmetic categories">
        <span>Skins</span>
        <span>Trails</span>
        <span>Kill Effects</span>
        <span>Emotes</span>
        <span>Titles</span>
        <span>Sound Packs</span>
      </div>
    </div>
  </section>

  <section class="section cta-section">
    <div class="cta-content">
      <p class="eyebrow">Ready to run?</p>
      <h2>Step into the neon and chase your cleanest run.</h2>
      <a class="store-badge" href={appStoreUrl} target="_blank" rel="noopener">
        <img src="https://tools.applemediaservices.com/api/badges/download-on-the-app-store/black/en-us?size=250x83" alt="Download on the App Store" />
      </a>
    </div>
  </section>
</BaseLayout>
